# Example Karpathy-style configuration for `joplin-brain`.
# Copy to `config.yaml` and adjust paths.
# Local default: repository-root `notes_root/` (directory is gitignored).

notes_root: ./notes_root
notes_glob: "**/*.md"

wiki_root: /absolute/path/to/compiled/wiki
wiki:
  glob: "**/*.md"

wiki_schema:
  path: ./wiki-schema.example.yaml
  strict: true

wiki_ingest:
  max_pages_per_run: 15
  min_pages_per_run: 10
  max_planner_rounds: 3

write_back:
  sources_enabled: false

ollama:
  base_url: http://127.0.0.1:11434
  embed_model: bge-m3
  chat_model: gemma2:2b
  timeout_ms: 120000
  embed_batch_size: 16

chroma:
  persist_path: data/chroma
  collection_sources: joplin_sources_mvp
  collection_wiki: joplin_wiki_mvp

chunk:
  size_chars: 1200
  overlap_chars: 200

watch:
  enabled: false
  debounce_ms: 2000

rag:
  top_k: 5
  max_context_chars: 6000
  retrieve_mode: wiki_first

lint:
  out_dir: reports
  duplicate_similarity_threshold: 0.92
  duplicate_scope: both
  source_link_check: true
  contradiction:
    max_pairs: 50
    timeout_ms: 180000

joplin_cli:
  enabled: false
  command: joplin
  preflight_argv:
    - config
    - version
  timeout_ms: 30000

# Optional: batch-export notes from Joplin Desktop database.sqlite into notes_root, then run pipelines.
# When enabled, database_path is required. For MVP, export_root must match notes_root (omit export_root to use notes_root).
joplin_sqlite_sync:
  enabled: false
  database_path: ""
  export_root: ""
  reconcile_mode: mirror
  busy_timeout_ms: 5000
  max_export_attempts: 5
  pipeline:
    run_index: true
    run_wiki_compile: true
  schedule:
    every_seconds: null
