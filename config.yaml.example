# Example Karpathy-style configuration for `joplin-brain`.
# Copy to `config.yaml` and adjust paths.
# Local default: repository-root `notes_root/` (directory is gitignored).
#
# 本檔 wiki_ingest／ollama 預設對齊「筆電可跑的較小 chat 模型」（如 gemma4:e4b）實測；
# 若機器與模型較大，可改回註解中的「高配預設」數值（見 README「本機小模型」）。

notes_root: ./notes_root
notes_glob: "**/*.md"

wiki_root: ./wiki_root
wiki:
  glob: "**/*.md"

wiki_schema:
  path: ./wiki-schema.example.yaml
  strict: true

wiki_ingest:
  # 小模型建議 5–8；高配可改 15
  max_pages_per_run: 8
  # 建議 ≤ required_hub_pages 數量或略高（schema 範例為 2 個 hub）；高配可改 10
  min_pages_per_run: 2
  # 每視窗至少幾個 topics/*.md（0=關閉；小模型建議 3）
  min_topic_pages_per_run: 3
  planner_reject_source_paths: true
  max_planner_rounds: 3
  # Omitting corpus_mode_enabled ⇒ true (notebook-wide digest + rotated excerpts).
  # Set explicitly to false if you rely on legacy 40-file planner digest / 5-file writer excerpt.
  # corpus_mode_enabled: false
  # 小模型 planner 建議 40（與舊版相容 digest 同量級）；高配可改 500（合法 40–1000）
  corpus_digest_max_files: 40
  corpus_digest_offset: 0
  # Multi-window digest sweep（單次 CLI 連跑多視窗）。需 corpus_mode_enabled true。
  # 進度：wiki_root/.joplin-llm-wiki/corpus-sweep-state.json（可用 state_path 覆寫）
  corpus_auto_sweep:
    enabled: true
    # 小模型建議 1–3 視窗／次，避免單次 invocation 過長
    max_windows_per_invocation: 2
    step_files: 40          # 省略時預設為 corpus_digest_max_files；必須 ≤ corpus_digest_max_files
    state_path: ""
    # false：--dry-run 只跑 1 個視窗且不推進 offset（預覽 planner 用）
    advance_state_on_dry_run: false
    # 單次 CLI 內連續 sweep 直到 cycle_complete（非 dry-run）；受 max_total_windows 上限
    run_until_cycle_complete: false
    max_total_windows_per_invocation: 500
  corpus_writer_excerpt_mode: filesystem_slice
  corpus_chroma_top_k: 8

write_back:
  sources_enabled: false

ollama:
  base_url: http://127.0.0.1:11434
  embed_model: bge-m3:latest
  # 本機較小 chat；請在 Ollama Modelfile／模型參數設定 num_ctx（本套件 API 未傳 options.num_ctx）
  chat_model: gemma4:e4b
  timeout_ms: 120000
  embed_batch_size: 16

chroma:
  persist_path: data/chroma
  collection_sources: joplin_sources_mvp
  collection_wiki: joplin_wiki_mvp

chunk:
  size_chars: 1200
  overlap_chars: 200

watch:
  enabled: false
  debounce_ms: 2000

rag:
  top_k: 5
  max_context_chars: 6000
  retrieve_mode: wiki_first

lint:
  out_dir: reports
  duplicate_similarity_threshold: 0.92
  duplicate_scope: both
  source_link_check: true
  contradiction:
    max_pairs: 50
    timeout_ms: 180000

joplin_cli:
  enabled: false
  command: joplin
  preflight_argv:
    - version
  timeout_ms: 30000

# Web Clipper / Data API：寫回開啟時 **必須** 設定非空 token，且 base_url 之 hostname 僅能為 127.0.0.1、localhost 或 ::1。
joplin_data_api:
  base_url: http://127.0.0.1:41184
  token: "" # 於 Joplin Desktop → 設定 → 網頁剪輯器 複製授權權杖
  timeout_ms: 30000

# LLM Wiki 編譯完成後可選將頁面寫回 Joplin（預設開啟）。啟用時須設定 joplin_data_api.token；否則 load-config CONFIG_INVALID。
# 寫回經 Data API（預設頂層 note-wiki；子筆記本依 wiki frontmatter 的 domain，見 README）。
joplin_wiki_writeback:
  # enabled 省略時視同 true
  parent_notebook_title: note-wiki
  topic_frontmatter_key: domain
  note_title_key: title
  max_cli_attempts: 3

# Optional: batch-export notes from Joplin Desktop database.sqlite into notes_root, then run pipelines.
# When enabled, database_path is required. For MVP, export_root must match notes_root (omit export_root to use notes_root).
joplin_sqlite_sync:
  enabled: false
  database_path: ""
  export_root: ""
  reconcile_mode: mirror
  busy_timeout_ms: 5000
  max_export_attempts: 5
  notebook_filter:
    enabled: false
    include_notebook_ids: []
    include_notebook_paths: []
    include_descendants: true
    notebook_path_style: joined_slug
    notebook_path_separator: "-"
    source_filename: title
  pipeline:
    run_index: true
    run_wiki_compile: true
  schedule:
    every_seconds: null
