# Example configuration for `joplin-llm-wiki`.
# Copy to `config.yaml` and adjust paths.
# Local default: repository-root `raw/` (directory is gitignored).
#
# Knowledge flow: this repo partially adopts gatelynch/llm-knowledge-base:
# raw/ -> raw/, wiki/ -> wiki/, plus brainstorming/ and artifacts/.
#
# 本檔預設為全庫掃描；若本機 Ollama 資源不足，可用 `wiki-compile --batch=true`
# 退回單批次 fallback。
# 若要以 Codex 月訂閱編譯 wiki，使用 `agent-compile` + 本機已登入 `codex exec`；
# 這不是 OpenAI API provider，也不使用 API key。

raw: ./raw
raw_glob: "**/*.md"

wiki: ./wiki
wiki_glob: "**/*.md"

wiki_schema:
  path: ./wiki-schema.example.yaml
  strict: true

wiki_ingest:
  max_pages_per_run: 15
  min_pages_per_run: 10
  # 每視窗至少幾個 concepts/*.md（0=關閉）
  min_topic_pages_per_run: 3
  planner_reject_source_paths: true
  max_planner_rounds: 3
  # Omitting corpus_mode_enabled ⇒ true (notebook-wide digest + rotated excerpts).
  # Set explicitly to false if you rely on legacy 40-file planner digest / 5-file writer excerpt.
  # corpus_mode_enabled: false
  # 小模型 planner 建議 40（與舊版相容 digest 同量級）；高配可改 500（合法 40–1000）
  corpus_digest_max_files: 40
  corpus_digest_offset: 0
  # Multi-window digest sweep（單次 CLI 連跑多視窗）。需 corpus_mode_enabled true。
  # 進度：wiki/.joplin-llm-wiki/corpus-sweep-state.json（可用 state_path 覆寫）
  corpus_auto_sweep:
    enabled: true
    # 小模型建議 1–3 視窗／次，避免單次 invocation 過長
    max_windows_per_invocation: 2
    step_files: 40          # 省略時預設為 corpus_digest_max_files；必須 ≤ corpus_digest_max_files
    state_path: ""
    # false：--dry-run 只跑 1 個視窗且不推進 offset（預覽 planner 用）
    advance_state_on_dry_run: false
    # 單次 CLI 內連續 sweep 直到 cycle_complete（非 dry-run）；受 max_total_windows 上限
    run_until_cycle_complete: true
    max_total_windows_per_invocation: 500
  corpus_writer_excerpt_mode: filesystem_slice

# Resume stages are CLI-only recovery controls, not persistent config:
#   wiki-compile --resume-stage concepts --dry-run
#   wiki-compile --resume-stage concepts
#   wiki-compile --resume-stage writeback --dry-run
# They read existing wiki/summaries or wiki/concepts from the local filesystem
# and still use only local Ollama plus the optional loopback Joplin Data API.
# No Chroma, embeddings, or remote service is added for resume mode.

write_back:
  sources_enabled: false

ollama:
  base_url: http://127.0.0.1:11434
  # 本機較小 chat；請在 Ollama Modelfile／模型參數設定 num_ctx（本套件 API 未傳 options.num_ctx）
  chat_model: gemma4:e4b
  timeout_ms: 120000

lint:
  out_dir: reports
  duplicate_similarity_threshold: 0.92
  duplicate_scope: both
  source_link_check: true
  contradiction:
    max_pairs: 50
    timeout_ms: 180000

joplin_cli:
  enabled: false
  command: joplin
  preflight_argv:
    - version
  timeout_ms: 30000

# Web Clipper / Data API：寫回開啟時 **必須** 設定非空 token，且 base_url 之 hostname 僅能為 127.0.0.1、localhost 或 ::1。
joplin_data_api:
  base_url: http://127.0.0.1:41184
  token: "" # 於 Joplin Desktop → 設定 → 網頁剪輯器 複製授權權杖
  timeout_ms: 30000

# LLM Wiki 編譯完成後可選將 wiki 頁面寫回 Joplin（預設開啟）。啟用時須設定 joplin_data_api.token；否則 load-config CONFIG_INVALID。
# compile 寫回經 Data API：預設頂層 @llm-wiki，下分 wiki/summaries、wiki/concepts、wiki/indexes。
# brainstorming / artifacts 只在需要整理問答、健康報告或作品時按需寫回。
joplin_wiki_writeback:
  # enabled 省略時視同 true
  parent_notebook_title: "@llm-wiki"
  wiki_notebook_title: wiki
  brainstorming_notebook_title: brainstorming
  artifacts_notebook_title: artifacts
  artifacts_project_notebook_title: "" # 僅 artifacts 按需寫回時需要
  topic_frontmatter_key: domain
  note_title_key: title
  max_cli_attempts: 3

# Optional: batch-export notes from Joplin Desktop database.sqlite into raw, then run pipelines.
# When enabled, database_path is required. For MVP, export_root must match raw (omit export_root to use raw).
joplin_sqlite_sync:
  enabled: false
  database_path: ""
  export_root: ""
  reconcile_mode: mirror
  busy_timeout_ms: 5000
  max_export_attempts: 5
  notebook_filter:
    enabled: false
    # 可用 `sqlite-sync --select-notebooks` 互動式寫入 ids；也可手動填 Joplin notebook path。
    include_notebook_ids: []
    include_notebook_paths: []
    include_descendants: true
    # 工作/專案A/會議 -> raw/工作-專案A-會議/<safe-title>.md
    notebook_path_style: joined_slug
    notebook_path_separator: "-"
    source_filename: title
  pipeline:
    # local: detect raw changes and run wiki-compile
    # agent: detect raw changes and run agent-compile via local codex exec
    # off: export/snapshot only, never compile from sqlite-sync
    compile_mode: local
    # Legacy compatibility: if compile_mode is omitted, run_wiki_compile true => local, false => off.
    # run_wiki_compile: true
  schedule:
    # null: one-shot sqlite-sync. Set seconds (e.g. 600) for in-process polling.
    # This is polling, not a filesystem watcher.
    every_seconds: null
